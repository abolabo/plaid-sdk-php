{
    "name": "abolabo/plaid-sdk-php",
    "description": "PHP implementation of Plaid's API as an SDK.",
    "keywords": [
        "plaid",
        "sdk",
        "php"
    ],
    "type": "library",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-curl": "*",
        "nimbly/shuttle": "2.0"
    },
    "autoload": {
        "psr-4": {
            "TomorrowIdeas\\Plaid\\" : "src"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "11.5.55",
        "vimeo/psalm": "6.16.1",
        "symfony/var-dumper": "v7.4.8",
        "php-coveralls/php-coveralls": "v2.9.1"
    },
    "autoload-dev": {
        "psr-4": {
            "TomorrowIdeas\\Plaid\\Tests\\": "tests"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Brent Scheffler",
            "email": "brent@brentscheffler.com"
        }
    ]
}
